---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ShadowCard from "@/components/fundations/containers/ShadowCard.astro";
// Content
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <section>
    <Wrapper
      variant="standard"
      class="h-dvh lg:h-[calc(100dvh-6rem)]flex flex-col items-end border-t border-base-900"
    >
      <ShadowCard
        class="relative overflow-hidden flex flex-col justify-center w-full bg-diamonds bg-cover bg-blend-overlay"
      >
        <div class="text-center">
          <Text
            tag="h1"
            variant="display3XL"
            class="text-white lg:text-balance font-thin tracking-tighter font-mono uppercase"
          >
            {frontmatter.page}
          </Text>
          <Text
            tag="p"
            variant="displayXS"
            class="text-base-300 lg:text-balance mt-4"
          >
            Updated {frontmatter.pubDate.toString().slice(0, 10)}
          </Text>
        </div>
      </ShadowCard>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="border-t border-base-900">
      <Wrapper variant="prose" class="max-w-xl mx-auto py-4">
        <slot />
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>
